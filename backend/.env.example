# ──────────────────────────────────────────────
# Adaptive Diagnostic Engine - Environment Config
# ──────────────────────────────────────────────

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=adaptive_engine

# OpenAI API Key (required for Phase 3 - AI Study Plans)
OPENAI_API_KEY=your-openai-api-key-here

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Adaptive Test Settings
MAX_QUESTIONS_PER_SESSION=10
INITIAL_ABILITY=0.5
